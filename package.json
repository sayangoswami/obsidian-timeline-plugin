{
	"name": "obsidian-timeline-view",
	"version": "1.0.0",
	"description": "Renders Markdown task lists as an interactive Gantt-style timeline.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs",
    	"dev": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --watch",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"obsidian": "latest",
		"esbuild": "^0.20.0",
		"typescript": "^5.0.0"
	}
}
