{
	"name": "obsidian-timeline-view",
	"version": "1.0.0",
	"description": "Renders Markdown task lists as an interactive Gantt-style timeline.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --external:obsidian",
  		"dev":   "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --external:obsidian --watch",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"vis-data": "^8.0.3",
		"vis-timeline": "^8.5.0"
	}
}
